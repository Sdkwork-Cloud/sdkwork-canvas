{
  "schemaVersion": 4,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-canvas",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.development": "configs/topology/standalone.development.env",
    "standalone.production": "configs/topology/standalone.production.env",
    "cloud.development": "configs/topology/cloud.development.env",
    "cloud.production": "configs/topology/cloud.production.env"
  },
  "envKeys": {
    "environment": "SDKWORK_CANVAS_ENVIRONMENT",
    "profileId": "SDKWORK_CANVAS_PROFILE_ID",
    "gatewayAutostart": "SDKWORK_CANVAS_PLATFORM_API_GATEWAY_AUTOSTART",
    "standaloneGatewayBind": "SDKWORK_CANVAS_APPLICATION_PUBLIC_INGRESS_BIND",
    "cloudGatewayBind": "SDKWORK_API_CLOUD_GATEWAY_BIND",
    "cloudGatewayConfig": "SDKWORK_API_CLOUD_GATEWAY_CONFIG",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL",
    "apiGatewayBaseUrl": "SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "SDKWORK_CANVAS_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_CANVAS_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_CANVAS_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "owner": "sdkwork-api-cloud-gateway",
      "bindEnv": "SDKWORK_API_CLOUD_GATEWAY_BIND",
      "httpUrlEnv": "SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "SDKWORK_CANVAS_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "canvas.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_CANVAS"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-canvas-standalone-gateway",
      "binary": "sdkwork-canvas-standalone-gateway"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-cloud-gateway",
      "binary": "sdkwork-api-cloud-gateway",
      "repository": "sdkwork-api-cloud-gateway",
      "configGlob": "configs/sdkwork-api-cloud-gateway.canvas.{profile}.toml"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-canvas-standalone-gateway",
            "binary": "sdkwork-canvas-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "sdkwork-canvas-pc-react",
            "script": "dev",
            "required": true
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": true
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-canvas-standalone-gateway",
            "binary": "sdkwork-canvas-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "sdkwork-canvas-pc-react",
            "script": "dev",
            "required": true
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway",
          "application.public-ingress"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-canvas-standalone-gateway",
            "binary": "sdkwork-canvas-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "sdkwork-canvas-pc-react",
            "script": "dev",
            "required": true
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-canvas-standalone-gateway",
            "binary": "sdkwork-canvas-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "sdkwork-canvas-pc-react",
            "script": "dev",
            "required": true
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-cloud-gateway.canvas.development.toml",
      "sdkwork-api-cloud-gateway.canvas.production.toml"
    ],
    "targets": [
      {
        "id": "platform-config-bundle-tar-gz",
        "profile": "platform-config-bundle",
        "platform": "all",
        "architecture": "all",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-canvas-api-gateway-config-*.tar.gz"
      }
    ]
  },
  "scripts": {
    "canvasDev": "scripts/canvas-dev.mjs"
  },
  "retired": {
    "envKeys": [
      "SDKWORK_CANVAS_BIND_ADDRESS",
      "SDKWORK_CANVAS_TOPOLOGY",
      "VITE_CANVAS_TOPOLOGY",
      "VITE_APP_API_BASE_URL",
      "VITE_API_BASE_URL",
      "SDKWORK_CANVAS_HOSTING",
      "VITE_SDKWORK_CANVAS_HOSTING"
    ],
    "cliFlags": [
      "--topology"
    ],
    "vocabulary": {
      "hosting": [
        "self-hosted",
        "cloud-hosted"
      ]
    }
  }
}
