    {
      "file": "DRIVE_SPEC.md",
      "path": "../../../sdkwork-specs/DRIVE_SPEC.md",
      "purpose": "Drive-backed file, folder, upload, and version ownership rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_SPEC.md",
      "purpose": "SDK generation, SDK dependency, and SDK integration rules."
    },
    {
