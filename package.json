{
  "name": "sdkwork-canvas",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:browser:postgres": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:browser:sqlite": "node scripts/canvas-dev.mjs --target browser --deployment-profile standalone --database sqlite",
    "dev:desktop": "pnpm dev:desktop:postgres:standalone",
    "dev:desktop:postgres": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone",
    "dev:desktop:sqlite": "node scripts/canvas-dev.mjs --target desktop --deployment-profile standalone --database sqlite",
    "dev:server": "pnpm exec sdkwork-app dev --runtime-target server --deployment-profile standalone",
    "gateway:run:standalone": "node scripts/gateway-standalone-run.mjs",
    "gateway:build:standalone": "cargo build -p sdkwork-canvas-standalone-gateway --bin sdkwork-canvas-standalone-gateway",
    "gateway:validate:standalone": "cargo check -p sdkwork-canvas-standalone-gateway",
    "gateway:package:standalone": "cargo build -p sdkwork-canvas-standalone-gateway --release --bin sdkwork-canvas-standalone-gateway",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "start": "node scripts/release/run-sdkwork-canvas-source-server.mjs start",
    "build": "pnpm exec sdkwork-app build",
    "build:desktop": "node scripts/release/build-sdkwork-canvas-production.mjs --target desktop",
    "test": "pnpm exec sdkwork-app test",
    "check": "pnpm exec sdkwork-app check",
    "check:deploy-standard": "node ../sdkwork-specs/tools/check-deploy-standard.mjs --root .",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs --root .",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "typecheck": "pnpm --dir apps/sdkwork-canvas-pc lint",
    "lint": "pnpm --dir apps/sdkwork-canvas-pc lint",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "check:commercial-readiness": "node scripts/release/commercial-readiness.mjs",
    "check:dependency-management": "node scripts/dependency-management-standard.test.mjs",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix canvas",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "check:unified-postgres-profile": "node ../sdkwork-specs/tools/check-unified-postgres-profile.mjs",
    "db:plan": "node scripts/dev/sdkwork-canvas-database-cli.mjs -- plan",
    "db:init": "node scripts/dev/sdkwork-canvas-database-cli.mjs -- init",
    "db:migrate": "node scripts/dev/sdkwork-canvas-database-cli.mjs -- migrate",
    "db:postgres:plan": "node scripts/dev/sdkwork-canvas-postgres-db.mjs --mode plan --config .env.postgres --dry-run",
    "db:postgres:init": "node scripts/dev/sdkwork-canvas-postgres-db.mjs --mode init --config .env.postgres",
    "db:postgres:migrate": "node scripts/dev/sdkwork-canvas-postgres-db.mjs --mode migrate --config .env.postgres",
    "sdk:shared:prepare": "node scripts/dev/prepare-shared-sdk-git-sources.mjs",
    "release:build": "node scripts/release/run-sdkwork-canvas-pc-release-build.mjs",
    "release:plan": "node scripts/release/plan-sdkwork-canvas-install-packages.mjs",
    "release:build:prod": "node scripts/release/build-sdkwork-canvas-production.mjs",
    "release:stage": "node scripts/release/stage-sdkwork-canvas-release-package.mjs",
    "release:package": "node scripts/release/build-sdkwork-canvas-install-package.mjs",
    "release:package:check": "node scripts/release/build-sdkwork-canvas-install-package.mjs --check --dry-run --all",
    "release:validate": "node scripts/release/validate-sdkwork-canvas-install-artifacts.mjs",
    "release:build:desktop": "node scripts/release/build-sdkwork-canvas-production.mjs --target desktop",
    "test:database-naming-standard": "node scripts/dev/sdkwork-canvas-database-naming-standard.test.mjs",
    "test:component-spec-consistency": "node scripts/dev/sdkwork-canvas-component-spec-consistency.test.mjs",
    "test:apis-authority-standard": "node scripts/dev/sdkwork-canvas-apis-authority-standard.test.mjs",
    "test:runtime-standard": "node scripts/dev/sdkwork-canvas-runtime-standard.test.mjs",
    "test:runtime-id-standard": "node scripts/dev/sdkwork-canvas-runtime-id-standard.test.mjs",
    "test:workflow-commercial-gates": "node scripts/run-commercial-gates-governance-node-tests.mjs",
    "test:sdkwork-workspace-structure-standard": "node scripts/sdkwork-workspace-structure-standard.test.mjs",
    "test:web-framework-standard": "node scripts/dev/sdkwork-canvas-web-framework-standard.test.mjs",
    "test:iam-auth-integration": "node scripts/dev/sdkwork-canvas-iam-auth-integration.test.mjs",
    "test:single-http-ingress": "node ../sdkwork-specs/tools/check-single-http-ingress.mjs --root .",
    "test:web-backend-standard": "node scripts/dev/sdkwork-canvas-web-backend-standard.test.mjs",
    "test:database-framework-bootstrap": "node scripts/dev/sdkwork-canvas-database-framework-bootstrap.test.mjs",
    "test:api-response-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_canvas_baseline.sql --module-id canvas --owner canvas-platform --prefixes canvas_ --engines postgres,sqlite",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "_sdkwork:build": "node scripts/release/build-sdkwork-canvas-production.mjs",
    "_sdkwork:test": "node --test scripts/verify-canvas-standard-architecture.test.mjs scripts/verify-canvas-contract-foundation.test.mjs scripts/verify-canvas-rust-service-skeleton.test.mjs scripts/verify-canvas-topology.test.mjs tests/contract/database-framework.contract.test.mjs",
    "_sdkwork:check": "pnpm run check:pnpm-script-standard && pnpm run check:agent-workflow-standard && pnpm db:validate && cargo check --workspace && node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "_sdkwork:verify": "cargo test --workspace && pnpm test && pnpm check",
    "_sdkwork:clean": "node -e \"require('fs').rmSync('apps/sdkwork-canvas-pc/dist',{recursive:true,force:true}); require('fs').rmSync('.runtime/dev-sites',{recursive:true,force:true})\"",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "release:plan:standalone": "pnpm exec sdkwork-app release:plan --deployment-profile standalone",
    "release:plan:cloud": "pnpm exec sdkwork-app release:plan --deployment-profile cloud",
    "release:build:standalone": "pnpm exec sdkwork-app release:build --deployment-profile standalone",
    "release:build:cloud": "pnpm exec sdkwork-app release:build --deployment-profile cloud",
    "release:stage:standalone": "pnpm exec sdkwork-app release:stage --deployment-profile standalone",
    "release:stage:cloud": "pnpm exec sdkwork-app release:stage --deployment-profile cloud",
    "release:package:standalone": "pnpm exec sdkwork-app release:package --deployment-profile standalone",
    "release:package:cloud": "pnpm exec sdkwork-app release:package --deployment-profile cloud",
    "release:validate:standalone": "pnpm exec sdkwork-app release:validate --deployment-profile standalone",
    "release:validate:cloud": "pnpm exec sdkwork-app release:validate --deployment-profile cloud",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --deployment-profile standalone",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --deployment-profile cloud",
    "dev:browser:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:desktop:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
