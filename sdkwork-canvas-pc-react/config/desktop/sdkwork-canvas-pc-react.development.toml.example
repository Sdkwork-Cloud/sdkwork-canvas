# SDKWork Canvas PC desktop host profile (development example)

[app]
key = "sdkwork-canvas-pc-react"
runtime_target = "desktop"
deployment_profile = "standalone"

[window]
title = "SDKWork Canvas"
width = 1440
height = 900

[runtime]
environment = "development"
config_profile = "dev"

[database]
engine = "sqlite"
file = "~/.sdkwork/canvas/data/canvas.sqlite"
max_connections = 1
