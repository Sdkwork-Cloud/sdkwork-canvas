# Copy this file to one of:
# - .env.development
# - .env.test
# - .env.production
#
# For local topology dev, copy `.env.development.local.example` to `.env.development.local`.

VITE_APP_ENV=development
VITE_APP_OWNER_MODE=tenant
VITE_SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=https://api-dev.sdkwork.com
SDKWORK_ACCESS_TOKEN=
# Optional override. Web defaults to web, desktop defaults to desktop.
# VITE_APP_PLATFORM=web
