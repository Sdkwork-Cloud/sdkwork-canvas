{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-canvas-app-sdk",
    "displayName": "SDKWork Canvas App API SDK",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-canvas/sdks/sdkwork-canvas-app-sdk",
    "domain": "canvas",
    "capability": "canvas",
    "status": "declared",
    "languages": [
      "typescript",
      "rust",
      "java",
      "python",
      "go"
    ],
    "generated": true,
    "private": false,
    "manifests": [
      "sdk-manifest.json"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "API_SPEC.md",
      "path": "../../../sdkwork-specs/API_SPEC.md",
      "purpose": "HTTP/OpenAPI and generated SDK contract rules."
    },
    {
      "file": "DRIVE_SPEC.md",
      "path": "../../../sdkwork-specs/DRIVE_SPEC.md",
      "purpose": "Drive-backed file, folder, upload, and version ownership rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_SPEC.md",
      "purpose": "SDK generation, SDK dependency, and SDK integration rules."
    },
    {
      "file": "SDK_WORKSPACE_GENERATION_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_WORKSPACE_GENERATION_SPEC.md",
      "purpose": "SDK workspace, SDK family naming, API authority naming, and OpenAPI generation rules."
    }
  ],
  "contracts": {
    "apiAuthority": {
      "name": "sdkwork-canvas-app-api",
      "prefix": "/app/v3/api",
      "authorityOpenApi": "../../apis/app-api/canvas/canvas-app-api.openapi.json",
      "derivedOpenApi": [
        "../../apis/app-api/canvas/canvas-app-api.openapi.json"
      ],
      "owner": "sdkwork-canvas",
      "standard": "../../../../sdkwork-specs/SDK_WORKSPACE_GENERATION_SPEC.md"
    },
    "publicExports": [],
    "runtimeEntrypoints": [
      "sdk-manifest.json"
    ],
    "sdkDependencies": [
      {
        "workspace": "sdkwork-iam-app-sdk",
        "role": "appbase-app-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-iam-app-api",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/iam-app-sdk",
          "rust": "sdkwork-iam-app-sdk",
          "java": "com.sdkwork:sdkwork-iam-app-sdk",
          "python": "sdkwork-iam-app-sdk",
          "go": "github.com/sdkwork/sdkwork-iam-app-sdk"
        }
      },
      {
        "workspace": "sdkwork-drive-app-sdk",
        "role": "drive-app-file-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-drive.app",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/drive-app-sdk",
          "rust": "sdkwork-drive-app-sdk",
          "java": "com.sdkwork:sdkwork-drive-app-sdk",
          "python": "sdkwork-drive-app-sdk",
          "go": "github.com/sdkwork/sdkwork-drive-app-sdk"
        }
      }
    ],
    "dependencyApiExports": [],
    "dependencyApiSurfaces": [],
    "sdkClients": [
      "SdkworkNotesAppClient"
    ],
    "events": [],
    "configKeys": [
      "sdk-manifest.json"
    ],
    "routeManifest": null
  },
  "integration": {
    "authority": "Root SDKWork specs remain authoritative. Local specs may extend but must not contradict them.",
    "dependencyPolicy": "Drive-owned content, folder, asset, uploader, and version capabilities are consumed through declared dependency SDKs, not copied into generated Notes transports.",
    "sdkPolicy": "Generated SDK clients are injected through service/runtime boundaries; consumers must not create raw HTTP clients or manual auth headers."
  },
  "verification": {
    "commands": [
      "node scripts/verify-canvas-contract-foundation.mjs"
    ]
  },
  "metadata": {
    "managedBy": "sdkwork-canvas-contract-foundation",
    "standardVersion": "2026-06-08"
  }
}
