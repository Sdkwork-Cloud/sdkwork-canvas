# SDKWork Canvas PC container runtime profile (development example)

[app]
key = "sdkwork-canvas-pc-react"
environment = "development"
config_profile = "dev"

[ingress]
application_public_http_url = "http://127.0.0.1:8787"
platform_api_gateway_http_url = "http://127.0.0.1:3900"

[database]
engine = "sqlite"
url = "sqlite:///data/canvas/product.db"
