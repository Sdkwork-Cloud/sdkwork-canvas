{
  "schemaVersion": 1,
  "component": {
    "identity": {
      "applicationCode": "canvas",
      "domain": "canvas",
      "kind": "application",
      "displayName": "SDKWork Canvas",
      "description": "AI-native visual workspace with Drive-backed pages, assets, and multi-tenant collaboration.",
      "vendor": "SDKWork",
      "license": "AGPL-3.0-or-later"
    },
    "surfaces": [
      { "name": "app-api", "kind": "http", "authority": "apis/app-api/canvas/canvas-app-api.openapi.json" },
      { "name": "backend-api", "kind": "http", "authority": "apis/backend-api/canvas/canvas-backend-api.openapi.json" }
    ],
    "canonicalSpecs": [
      { "path": "../sdkwork-specs/SOUL.md", "purpose": "agent execution soul" },
      { "path": "../sdkwork-specs/API_SPEC.md", "purpose": "HTTP API envelope and contracts" },
      { "path": "../sdkwork-specs/WEB_FRAMEWORK_SPEC.md", "purpose": "mandatory web framework integration" },
      { "path": "../sdkwork-specs/DATABASE_FRAMEWORK_SPEC.md", "purpose": "database lifecycle" },
      { "path": "../sdkwork-specs/DRIVE_SPEC.md", "purpose": "file upload via Drive" },
      { "path": "../sdkwork-specs/PAGINATION_SPEC.md", "purpose": "list/search pagination" },
      { "path": "../sdkwork-specs/APP_PC_ARCHITECTURE_SPEC.md", "purpose": "PC application architecture" }
    ],
    "frameworks": [
      { "name": "sdkwork-web-framework", "path": "../sdkwork-web-framework", "required": true },
      { "name": "sdkwork-database", "path": "../sdkwork-database", "required": true },
      { "name": "sdkwork-utils", "path": "../sdkwork-utils", "required": true },
      { "name": "sdkwork-drive", "path": "../sdkwork-drive", "required": true },
      { "name": "sdkwork-discovery", "path": "../sdkwork-discovery", "required": false, "deferred": true, "reason": "No RPC services in Phase 1 (ADR-0002)" }
    ],
    "verification": [
      { "command": "cargo check --workspace", "purpose": "Rust compile" },
      { "command": "pnpm check:pnpm-script-standard", "purpose": "pnpm script standard" },
      { "command": "pnpm db:validate", "purpose": "database framework standard" },
      { "command": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .", "purpose": "API envelope" }
    ]
  }
}
