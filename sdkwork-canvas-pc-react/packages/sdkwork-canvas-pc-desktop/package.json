{
  "name": "@sdkwork/canvas-pc-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite --host 127.0.0.1 --port 1430 --strictPort",
    "dev:desktop:test-runner": "node ../../scripts/run-with-app-mode.mjs test -- pnpm exec vite --host 127.0.0.1 --port 1430 --strictPort --mode test",
    "build": "vite build --mode production",
    "build:desktop": "tauri icon src-tauri/app-icon.svg && tauri build",
    "build:desktop:icon": "tauri icon src-tauri/app-icon.svg",
    "check:desktop:toolchain": "tauri info",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdkwork/canvas-pc-core": "workspace:*",
    "@sdkwork/canvas-pc-i18n": "workspace:*",
    "@sdkwork/canvas-pc-shell": "workspace:*",
    "@tauri-apps/api": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/vite": "catalog:"
  },
  "devDependencies": {
    "@tauri-apps/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "^29.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.2"
  }
}
