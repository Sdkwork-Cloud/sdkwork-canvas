{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-canvas-sdk",
    "displayName": "SDKWork Canvas Open API SDK",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-canvas/sdks/sdkwork-canvas-sdk",
    "domain": "canvas",
    "capability": "canvas",
    "status": "declared",
    "languages": [
      "typescript",
      "rust",
      "java",
      "python",
      "go"
