# Copy to `.env.development.local` for local Notes API + topology profile overrides.
VITE_APP_ENV=development
VITE_APP_OWNER_MODE=tenant

# application.public-ingress — Notes app SDK
VITE_SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:8787

# platform.api-gateway — appbase IAM / shared platform SDKs
VITE_SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900

SDKWORK_ACCESS_TOKEN=
