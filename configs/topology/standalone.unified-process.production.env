# standalone.unified-process.production
SDKWORK_CANVAS_DEPLOYMENT_PROFILE=standalone
SDKWORK_CANVAS_SERVICE_LAYOUT=unified-process
SDKWORK_CANVAS_ENVIRONMENT=production
SDKWORK_CANVAS_PROFILE_ID=standalone.unified-process.production

SDKWORK_CANVAS_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:8787
SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:8787
SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_CANVAS_PLATFORM_API_GATEWAY_AUTOSTART=false

SDKWORK_CANVAS_USE_MEMORY_DRIVE=0
SDKWORK_DRIVE_FACADE_URL=https://api.sdkwork.com

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork/database-password
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=32

VITE_SDKWORK_CANVAS_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_CANVAS_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:8787
VITE_SDKWORK_CANVAS_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
