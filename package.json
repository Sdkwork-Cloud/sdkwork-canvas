{
  "name": "sdkwork-canvas-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "scripts": {
    "dev": "node scripts/canvas-dev.mjs --runtime-target browser --database postgres --service-layout unified-process --deployment-profile standalone",
    "dev:browser": "node scripts/canvas-dev.mjs --runtime-target browser --database postgres --service-layout unified-process --deployment-profile standalone",
    "dev:browser:cloud": "node scripts/canvas-dev.mjs --runtime-target browser --database postgres --service-layout split-services --deployment-profile cloud",
    "dev:browser:split-services": "node scripts/canvas-dev.mjs --runtime-target browser --database postgres --service-layout split-services --deployment-profile standalone",
    "dev:desktop": "node scripts/canvas-dev.mjs --runtime-target desktop --database postgres --service-layout unified-process --deployment-profile standalone",
    "dev:desktop:cloud": "node scripts/canvas-dev.mjs --runtime-target desktop --database postgres --service-layout split-services --deployment-profile cloud",
    "gateway:run:standalone": "node scripts/run-canvas-standalone-gateway.mjs",
    "build": "cargo build --workspace",
    "test": "pnpm topology:validate && pnpm test:topology && pnpm test:topology-baggage && pnpm test:contracts && pnpm test:iam-application-bootstrap-standard",
    "check": "pnpm run check:app-composition && cargo check --workspace && pnpm check:pnpm-script-standard && pnpm check:architecture-alignment && pnpm check:deploy-standard && pnpm topology:validate && pnpm db:validate && pnpm api:check",
    "check:deploy-standard": "node ../sdkwork-specs/tools/check-deploy-standard.mjs",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs",
    "deploy:plan": "node ../sdkwork-specs/tools/deployctl.mjs plan --root .",
    "verify": "cargo test --workspace && pnpm test && pnpm run check:app-composition",
    "clean": "cargo clean",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --application-code-prefix canvas",
    "check:architecture-alignment": "node --test scripts/verify-canvas-standard-architecture.test.mjs",
    "api:check": "node tools/canvas_sdk_generate.mjs --check",
    "api:materialize": "node scripts/sync-canvas-api-framework-metadata.mjs",
    "sdk:check": "node tools/canvas_sdk_generate.mjs --check",
    "sdk:generate": "node tools/canvas_sdk_generate.mjs",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "gateway:matrix:cloud": "node scripts/print-gateway-package-matrix.mjs --profile platform-config-bundle",
    "gateway:package:cloud": "node scripts/gateway-cloud-bundle.mjs bundle",
    "gateway:validate:cloud": "node scripts/gateway-cloud-bundle.mjs validate",
    "gateway:matrix": "node scripts/print-gateway-package-matrix.mjs --profile all",
    "test:topology": "node --test --experimental-test-isolation=none scripts/verify-canvas-topology.test.mjs",
    "test:topology-baggage": "node --test scripts/dev/sdkwork-canvas-topology-baggage.test.mjs",
    "test:iam-application-bootstrap-standard": "node scripts/dev/sdkwork-canvas-iam-application-bootstrap-standard.test.mjs",
    "test:contracts": "node --test --experimental-test-isolation=none scripts/verify-canvas-contract-foundation.test.mjs && node --test --experimental-test-isolation=none scripts/verify-canvas-rust-service-skeleton.test.mjs && node --test --experimental-test-isolation=none scripts/verify-canvas-standard-architecture.test.mjs",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_canvas_baseline.sql --module-id canvas --owner canvas-platform --prefixes canvas_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
